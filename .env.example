# Database (required for API)
DATABASE_URL="postgresql://user:password@localhost:5432/keymaker?schema=public"

# API
NODE_ENV=development
PORT=3001

# Auth (JWT)
JWT_SECRET="change-me-in-production-min-32-chars"

# Web app (optional; for API URL when calling from browser)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
