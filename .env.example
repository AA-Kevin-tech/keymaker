# Database (required for API)
DATABASE_URL="postgresql://user:password@localhost:5432/keymaker?schema=public"

# API
NODE_ENV=development
PORT=3001

# Auth (JWT)
JWT_SECRET="change-me-in-production-min-32-chars"

# Web app — browser (and fallback for server)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Web app — server-side fetches (RSC). If unset, server uses NEXT_PUBLIC_API_URL.
# When web and API are on different hosts, set both to the same API base URL.
# API_URL=http://localhost:3001/api

# Public URL of the web app (verification links in emails). Default: http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# Resend (https://resend.com) — optional in local dev; logs link to console instead. Required in production to send mail.
# RESEND_API_KEY=
# EMAIL_FROM="Keymaker <onboarding@resend.dev>"
