generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  open
  dismissed
  actioned
}

enum AppealStatus {
  open
  upheld
  reversed
  modified
  closed
}

enum UserRestrictionType {
  posting_block
  rating_block
  temp_suspend
  permanent_ban
}

enum ModeratorRoleName {
  super_admin
  platform_moderator
  community_admin
  community_moderator
}

/// Who soft-deleted the content. Cleared on restore. Null when the row is active.
enum ContentDeletionKind {
  author_deleted
  moderator_removed
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  passwordHash String @map("password_hash")
  createdAt DateTime @default(now())

  reputationClarity  Float @default(0)
  reputationEvidence Float @default(0)
  reputationKindness Float @default(0)
  reputationNovelty  Float @default(0)

  posts             Post[]
  comments          Comment[]
  ratings           Rating[]
  moderationActions              ModerationAction[]
  emailVerificationToken       EmailVerificationToken?
  reportsFiled                 Report[]             @relation("ReportReporter")
  reportsReviewed              Report[]             @relation("ReportReviewedBy")
  restrictionsSubject          UserRestriction[]    @relation("RestrictionSubject")
  restrictionsCreated          UserRestriction[]    @relation("RestrictionCreatedBy")
  restrictionsLifted           UserRestriction[]    @relation("RestrictionLiftedBy")
  appealsFiled                 Appeal[]             @relation("AppealAppellant")
  appealsReviewed              Appeal[]             @relation("AppealReviewedBy")
  moderatorNotesAbout          ModeratorNote[]      @relation("ModeratorNoteSubject")
  moderatorNotesAuthored       ModeratorNote[]      @relation("ModeratorNoteAuthor")
  moderatorRoles               ModeratorRole[]

  @@map("users")
}

/// One pending verification token per user (rotated on resend).
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model Community {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  createdAt            DateTime @default(now())
  weightClarity        Float    @default(1)
  weightEvidence       Float    @default(1)
  weightKindness       Float    @default(1)
  weightNovelty        Float    @default(1)
  decayHalfLifeSeconds Int      @default(86400)

  posts               Post[]
  moderationActions   ModerationAction[]
  userRestrictions    UserRestriction[]
  moderatorNotes      ModeratorNote[]
  moderatorRoles      ModeratorRole[]

  @@map("communities")
}

model Post {
  id          String    @id @default(cuid())
  title       String
  body        String?   @db.Text
  communityId String    @map("community_id")
  authorId    String    @map("author_id")
  createdAt   DateTime  @default(now())
  deletedAt         DateTime?            @map("deleted_at")
  deletionKind      ContentDeletionKind? @map("deletion_kind")

  cachedClarity  Float @default(0)
  cachedEvidence Float @default(0)
  cachedKindness Float @default(0)
  cachedNovelty  Float @default(0)
  cachedScore   Float @default(0)
  ratingCount   Int   @default(0)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]

  @@index([communityId])
  @@index([authorId])
  @@map("posts")
}

model Comment {
  id        String    @id @default(cuid())
  body      String    @db.Text
  postId    String    @map("post_id")
  authorId  String    @map("author_id")
  parentId  String?   @map("parent_id")
  createdAt DateTime  @default(now())
  deletedAt         DateTime?            @map("deleted_at")
  deletionKind      ContentDeletionKind? @map("deletion_kind")

  cachedClarity  Float @default(0)
  cachedEvidence Float @default(0)
  cachedKindness Float @default(0)
  cachedNovelty  Float @default(0)
  cachedScore   Float @default(0)
  ratingCount   Int   @default(0)

  post    Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model Rating {
  id         String   @id @default(cuid())
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  raterId    String   @map("rater_id")
  clarity    Int
  evidence   Int
  kindness   Int
  novelty    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rater User @relation(fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, raterId])
  @@index([targetType, targetId])
  @@index([raterId])
  @@map("ratings")
}

model ModerationAction {
  id          String   @id @default(cuid())
  actionType  String   @map("action_type")
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  moderatorId String   @map("moderator_id")
  communityId String?  @map("community_id")
  reasonCode  String?  @map("reason_code")
  /// Free-text explanation; services use `reasonText` at the API boundary.
  reason    String? @db.Text
  /// JSON: relatedReportId, targetUserId, restrictionId, noteId (see moderation-audit.service).
  metadata  Json?
  createdAt   DateTime @default(now())

  moderator User       @relation(fields: [moderatorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  appeals   Appeal[]

  @@index([communityId])
  @@map("moderation_actions")
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String       @map("reporter_id")
  targetType   String       @map("target_type")
  targetId     String       @map("target_id")
  reasonCode   String       @map("reason_code")
  reasonText   String?      @map("reason_text") @db.Text
  status       ReportStatus @default(open)
  createdAt    DateTime     @default(now()) @map("created_at")
  reviewedById String?      @map("reviewed_by")
  reviewedAt   DateTime?    @map("reviewed_at")

  reporter   User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReportReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@map("reports")
}

model UserRestriction {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  restrictionType UserRestrictionType @map("restriction_type")
  communityId     String?             @map("community_id")
  reasonCode      String?             @map("reason_code")
  reasonText      String?             @map("reason_text") @db.Text
  startsAt        DateTime            @map("starts_at")
  endsAt          DateTime?           @map("ends_at")
  createdById     String              @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")
  isActive        Boolean             @default(true) @map("is_active")
  deactivatedAt   DateTime?           @map("deactivated_at")
  deactivatedById String?             @map("deactivated_by")

  user          User       @relation("RestrictionSubject", fields: [userId], references: [id], onDelete: Cascade)
  community     Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy     User       @relation("RestrictionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  deactivatedBy User?      @relation("RestrictionLiftedBy", fields: [deactivatedById], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([communityId])
  @@index([endsAt])
  @@map("user_restrictions")
}

model Appeal {
  id                 String       @id @default(cuid())
  moderationActionId String       @map("moderation_action_id")
  appellantId        String       @map("appellant_id")
  appealText         String       @map("appeal_text") @db.Text
  status             AppealStatus @default(open)
  reviewedById       String?      @map("reviewed_by")
  reviewedAt         DateTime?    @map("reviewed_at")
  decisionNote       String?      @map("decision_note") @db.Text
  createdAt          DateTime     @default(now()) @map("created_at")

  moderationAction ModerationAction @relation(fields: [moderationActionId], references: [id], onDelete: Restrict)
  appellant        User             @relation("AppealAppellant", fields: [appellantId], references: [id], onDelete: Cascade)
  reviewedBy       User?            @relation("AppealReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([moderationActionId])
  @@index([appellantId])
  @@index([createdAt])
  @@map("appeals")
}

model ModeratorNote {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  moderatorId String   @map("moderator_id")
  communityId String?  @map("community_id")
  noteText    String   @map("note_text") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user      User       @relation("ModeratorNoteSubject", fields: [userId], references: [id], onDelete: Cascade)
  moderator User       @relation("ModeratorNoteAuthor", fields: [moderatorId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([moderatorId])
  @@index([communityId])
  @@map("moderator_notes")
}

model ModeratorRole {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  communityId String?           @map("community_id")
  roleName    ModeratorRoleName @map("role_name")
  createdAt   DateTime          @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([communityId])
  @@index([roleName])
  @@map("moderator_roles")
}
